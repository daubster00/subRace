DISPLAY_LIMIT=50
BACKGROUND_LIMIT=150
YUTURA_INTERVAL_HOURS=48
YUTURA_REQUEST_DELAY_MS=1500
# YOUTUBE_POLL_INTERVAL_HOURS accepts fractional values for testing.
# Examples: 6 (prod), 0.0833 (5min), 0.0167 (1min). Floor: 0.01h (~36s).
YOUTUBE_POLL_INTERVAL_HOURS=6
# Surge metric baseline window. Drop to e.g. 0.25 (15min) while testing with
# a fast poll cadence so the Trending panel populates without waiting 24h.
SURGE_WINDOW_HOURS=24
ESTIMATION_SAFETY_RATIO=0.85
RANK_ALERT_ABSOLUTE_THRESHOLD=10000
RANK_ALERT_TIME_THRESHOLD_HOURS=1
LIVE_VIEWER_POLL_INTERVAL_SECONDS=60
CLIENT_CHANNEL_ID=
BASIC_AUTH_USERNAME=
BASIC_AUTH_PASSWORD=
YOUTUBE_API_KEY=
TIMEZONE=Asia/Tokyo
REGION=JP

# Docker-only: host port published for the Next.js web container.
# Defaults to 3100 to avoid colliding with other local Docker stacks.
SUBRACE_PORT=3100
